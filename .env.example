# .env.example — Copy this file to .env and fill in your values.
# NEVER commit the real .env file. It is in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Groq API key. Get one free at: https://console.groq.com
# Keys begin with "gsk_"
GROQ_API_KEY=gsk_your_key_here

# ── Optional model overrides ──────────────────────────────────────────────────
# Defaults shown below. Change only if you want to experiment with other models.
# Run `python -c "from groq import Groq; import os; [print(m.id) for m in Groq(api_key=os.environ['GROQ_API_KEY']).models.list().data]"` to list available models.

# Model used to generate the 3 prompt strategies (needs good reasoning)
# GENERATOR_MODEL=qwen/qwen3.6-27b

# Model used to execute the prompts against test cases
# RUNNER_MODEL=openai/gpt-oss-20b

# Model used to score each output (temperature always forced to 0)
# EVALUATOR_MODEL=openai/gpt-oss-20b

# ── Optional tuning ───────────────────────────────────────────────────────────

# Max parallel LLM calls at once. Keep <=8 on Groq free tier.
# MAX_CONCURRENT=6
